# Copy to .env and fill in.
# At minimum, ANTHROPIC_API_KEY is required for the hot-path extraction.
# Voice input requires OPENAI_API_KEY (Whisper).
# Vision OCR uses GEMINI_API_KEY when available, falls back to ANTHROPIC.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

LOG_LEVEL=INFO

# ─── Auth (multi-user) ──────────────────────────────────────────────────
# Folio supports sign-up + login per user. Each user's data is partitioned
# by user_id. ALLOW_SIGNUP=false locks the instance to existing users
# (useful once your family / friends have signed up).
JWT_SECRET=
ALLOW_SIGNUP=true
