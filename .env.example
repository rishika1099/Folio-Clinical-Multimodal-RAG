# Copy to .env and fill in.
# At minimum, ANTHROPIC_API_KEY is required for the hot-path extraction.
# Voice input requires OPENAI_API_KEY (Whisper).
# Vision OCR uses GEMINI_API_KEY when available, falls back to ANTHROPIC.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

LOG_LEVEL=INFO

# ─── Auth ──────────────────────────────────────────────────────────────
# Folio is single-user. To require sign-in, set BOTH of the following.
# Leave APP_PASSWORD blank to disable auth (only safe on localhost).
APP_PASSWORD=
JWT_SECRET=
